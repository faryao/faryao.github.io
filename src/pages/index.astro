---
const apps = [
  {
    name: 'Yuan’s Diary',
    description: 'A small public diary, written one day at a time.',
    href: 'https://faryao.github.io/public-diary/',
    icon: 'diary',
    lang: 'en',
    isNew: true,
  },
  {
    name: '爱尔兰道路规则',
    description: '爱尔兰《道路规则》中文版',
    href: 'https://faryao.github.io/irish-driver-rules-zh/',
    icon: 'road',
    lang: 'zh-Hans',
  },
  {
    name: '道路使用者指南',
    description: '爱尔兰道路使用者指南中文版',
    href: 'https://faryao.github.io/rsa-road-users-zh/',
    icon: 'people',
    lang: 'zh-Hans',
  },
  {
    name: 'GitHub',
    description: 'Yuan Yao on GitHub',
    href: 'https://github.com/faryao',
    icon: 'code',
    lang: 'en',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Yuan Yao’s projects, notes, and practical public-interest resources." />
    <meta name="theme-color" content="#182654" />
    <title>Yuan Yao — Home</title>
    <script is:inline data-goatcounter="https://faryao.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div class="wallpaper" aria-hidden="true">
      <span class="glow glow-one"></span>
      <span class="glow glow-two"></span>
      <span class="glow glow-three"></span>
    </div>

    <div class="desktop">
      <header class="topbar">
        <a class="identity" href="/" aria-label="Yuan Yao, home">
          <span class="avatar">YY</span>
          <span class="identity-copy">
            <strong>Yuan Yao</strong>
            <small>My home screen</small>
          </span>
        </a>

        <div class="status" aria-label="Device status">
          <time id="local-time">--:--</time>
          <svg class="wifi" viewBox="0 0 20 16" role="img" aria-label="Online">
            <path d="M2 5.2a12.2 12.2 0 0 1 16 0M5 8.5a7.6 7.6 0 0 1 10 0M8.2 12a2.8 2.8 0 0 1 3.6 0" />
            <circle cx="10" cy="14" r="1" />
          </svg>
          <span class="battery" aria-hidden="true"><span></span></span>
        </div>
      </header>

      <main>
        <h1>Projects</h1>
        <nav class="app-grid" aria-label="Projects and links">
          {apps.map((app) => (
            <a
              class="app"
              href={app.href}
              target="_blank"
              rel="noreferrer"
            >
              <span class:list={['app-icon', `icon-${app.icon}`]}>
                {app.icon === 'diary' && (
                  <svg viewBox="0 0 88 88" aria-hidden="true">
                    <path class="diary-sheet" d="M24 14h36a8 8 0 0 1 8 8v50H24a8 8 0 0 1-8-8V22a8 8 0 0 1 8-8Z" />
                    <path class="diary-spine" d="M27 14v58" />
                    <circle class="diary-dot" cx="38" cy="29" r="4" />
                    <path class="diary-lines" d="M47 28h11M37 42h21M37 52h21M37 62h14" />
                  </svg>
                )}

                {app.icon === 'road' && (
                  <svg viewBox="0 0 88 88" aria-hidden="true">
                    <circle class="road-sun" cx="63" cy="23" r="8" />
                    <path class="road-hill road-hill-back" d="M0 52 25 29l18 17 14-13 31 25v30H0Z" />
                    <path class="road-hill road-hill-front" d="M0 62 21 44l18 15 15-12 34 24v17H0Z" />
                    <path class="road-surface" d="m29 88 11-38h10l13 38Z" />
                    <path class="road-line" d="m44 56 1 7m2 6 2 13" />
                  </svg>
                )}

                {app.icon === 'people' && (
                  <svg viewBox="0 0 88 88" aria-hidden="true">
                    <path class="people-path" d="M-2 77c18-15 30-18 48-16 18 1 30-5 44-18v45H-2Z" />
                    <circle class="person-main" cx="42" cy="27" r="9" />
                    <path class="person-main" d="M26 66c2-18 7-28 16-28s15 10 18 28Z" />
                    <circle class="person-side" cx="68" cy="38" r="6" />
                    <path class="person-side" d="M59 64c1-12 4-19 10-19 7 0 10 7 12 19Z" />
                    <circle class="person-side" cx="17" cy="41" r="5" />
                    <path class="person-side" d="M7 65c1-11 4-17 10-17s9 6 10 17Z" />
                  </svg>
                )}

                {app.icon === 'code' && (
                  <svg viewBox="0 0 88 88" aria-hidden="true">
                    <rect class="code-window" x="13" y="18" width="62" height="52" rx="10" />
                    <circle class="code-dot" cx="23" cy="28" r="2" />
                    <circle class="code-dot" cx="30" cy="28" r="2" />
                    <circle class="code-dot" cx="37" cy="28" r="2" />
                    <path class="code-mark" d="m34 43-8 7 8 7m20-14 8 7-8 7m-5-20-9 26" />
                  </svg>
                )}

                {app.isNew && <span class="badge" aria-hidden="true">NEW</span>}
              </span>
              <span class="app-name" lang={app.lang}>{app.name}</span>
              <span class="sr-only">
                {app.isNew && 'New project. '}
                <span lang={app.lang}>{app.description}</span>
                {' Opens in a new tab.'}
              </span>
            </a>
          ))}
        </nav>
      </main>

      <footer>
        <div class="page-dots" aria-hidden="true"><span></span><span></span><span></span></div>
        <p>© {new Date().getFullYear()} Yuan Yao</p>
      </footer>
    </div>

    <script>
      const clock = document.querySelector<HTMLTimeElement>('#local-time');
      const formatter = new Intl.DateTimeFormat([], {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      });

      const updateClock = () => {
        if (!clock) return;
        const now = new Date();
        clock.textContent = formatter.format(now);
        clock.dateTime = now.toISOString();
      };

      updateClock();
      window.setInterval(updateClock, 30_000);
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif;
    font-synthesis: none;
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    min-height: 100%;
    background: #182654;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    min-height: 100svh;
    margin: 0;
    color: #fff;
  }

  a {
    color: inherit;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .wallpaper {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 12% 8%, rgba(91, 201, 255, .6), transparent 32%),
      radial-gradient(circle at 92% 12%, rgba(158, 105, 255, .58), transparent 34%),
      linear-gradient(145deg, #0d1b40 0%, #334d94 46%, #d37488 100%);
  }

  .wallpaper::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: .12;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.82' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.38'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  .glow {
    position: absolute;
    display: block;
    border-radius: 999px;
    filter: blur(2px);
  }

  .glow-one {
    top: 22%;
    left: -12vw;
    width: 45vw;
    height: 45vw;
    background: rgba(72, 213, 229, .18);
  }

  .glow-two {
    right: -16vw;
    bottom: -18vw;
    width: 58vw;
    height: 58vw;
    background: rgba(255, 183, 128, .2);
  }

  .glow-three {
    top: 40%;
    left: 55%;
    width: 18vw;
    height: 18vw;
    background: rgba(207, 145, 255, .16);
  }

  .desktop {
    position: relative;
    z-index: 1;
    width: min(1120px, 100%);
    min-height: 100vh;
    min-height: 100svh;
    margin-inline: auto;
    padding:
      max(24px, env(safe-area-inset-top))
      max(32px, env(safe-area-inset-right))
      max(24px, env(safe-area-inset-bottom))
      max(32px, env(safe-area-inset-left));
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .identity {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .avatar {
    width: 46px;
    height: 46px;
    border: 1px solid rgba(255, 255, 255, .36);
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, .16);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .32), 0 12px 30px rgba(7, 14, 42, .14);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    font-size: 14px;
    font-weight: 750;
    letter-spacing: -.04em;
  }

  .identity-copy {
    display: grid;
    gap: 2px;
  }

  .identity-copy strong {
    font-size: 15px;
    letter-spacing: -.01em;
  }

  .identity-copy small {
    color: rgba(255, 255, 255, .68);
    font-size: 12px;
  }

  .status {
    min-height: 40px;
    padding: 0 14px;
    border: 1px solid rgba(255, 255, 255, .2);
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(16, 26, 63, .18);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .14);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
  }

  .status time {
    min-width: 42px;
    font-size: 12px;
    font-variant-numeric: tabular-nums;
    font-weight: 650;
  }

  .wifi {
    width: 17px;
    height: 14px;
    overflow: visible;
    fill: currentColor;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    fill-rule: evenodd;
  }

  .wifi path {
    fill: none;
  }

  .battery {
    position: relative;
    width: 20px;
    height: 10px;
    padding: 2px;
    border: 1.4px solid rgba(255, 255, 255, .8);
    border-radius: 3px;
  }

  .battery::after {
    content: '';
    position: absolute;
    top: 2px;
    right: -3px;
    width: 2px;
    height: 4px;
    border-radius: 0 2px 2px 0;
    background: rgba(255, 255, 255, .8);
  }

  .battery span {
    display: block;
    width: 78%;
    height: 100%;
    border-radius: 1px;
    background: #fff;
  }

  main {
    width: 100%;
    align-self: center;
    padding: clamp(64px, 10vh, 118px) 0;
  }

  h1 {
    margin: 0 0 clamp(34px, 5vh, 54px);
    font-size: clamp(26px, 4vw, 46px);
    font-weight: 650;
    letter-spacing: -.045em;
    text-align: center;
    text-shadow: 0 2px 20px rgba(8, 17, 47, .22);
  }

  .app-grid {
    width: min(760px, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(110px, 1fr));
    gap: clamp(28px, 5vw, 68px);
  }

  .app {
    min-width: 0;
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 13px;
    text-align: center;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .app-icon {
    position: relative;
    width: clamp(82px, 9vw, 104px);
    aspect-ratio: 1;
    overflow: visible;
    border: 1px solid rgba(255, 255, 255, .28);
    border-radius: 24%;
    display: grid;
    place-items: center;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .32),
      0 22px 36px rgba(5, 12, 38, .24),
      0 3px 8px rgba(5, 12, 38, .18);
    transition: transform .22s cubic-bezier(.2, .8, .2, 1), box-shadow .22s ease;
  }

  .app-icon::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(145deg, rgba(255, 255, 255, .22), transparent 48%);
    pointer-events: none;
  }

  .app-icon svg {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
  }

  .app:hover .app-icon {
    transform: translateY(-8px) scale(1.035);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .36),
      0 30px 42px rgba(5, 12, 38, .3),
      0 5px 10px rgba(5, 12, 38, .2);
  }

  .app:active .app-icon {
    transform: scale(.94);
    transition-duration: .08s;
  }

  .app:focus-visible {
    outline: none;
  }

  .identity:focus-visible {
    border-radius: 14px;
    outline: 3px solid #fff;
    outline-offset: 5px;
  }

  .app:focus-visible .app-icon {
    outline: 3px solid #fff;
    outline-offset: 5px;
  }

  .app-name {
    max-width: 132px;
    color: rgba(255, 255, 255, .96);
    font-size: 14px;
    font-weight: 580;
    line-height: 1.3;
    letter-spacing: -.01em;
    text-shadow: 0 2px 7px rgba(4, 10, 33, .58);
  }

  .badge {
    position: absolute;
    z-index: 2;
    top: -8px;
    right: -13px;
    padding: 5px 7px 4px;
    border: 2px solid rgba(255, 255, 255, .92);
    border-radius: 999px;
    background: #ff3d63;
    box-shadow: 0 5px 12px rgba(78, 10, 32, .34);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: .04em;
  }

  .icon-diary {
    background: linear-gradient(145deg, #ff9f45, #ff4d70 90%);
  }

  .diary-sheet {
    fill: #fff9ec;
    filter: drop-shadow(0 5px 5px rgba(126, 38, 32, .2));
  }

  .diary-spine,
  .diary-lines {
    fill: none;
    stroke: #e8a1a4;
    stroke-linecap: round;
  }

  .diary-spine {
    stroke-width: 2;
  }

  .diary-lines {
    stroke-width: 3;
  }

  .diary-dot {
    fill: #ff5675;
  }

  .icon-road {
    background: linear-gradient(145deg, #37b9dc, #1772c9);
  }

  .road-sun {
    fill: #ffe893;
  }

  .road-hill-back {
    fill: #5bc9a3;
  }

  .road-hill-front {
    fill: #17936f;
  }

  .road-surface {
    fill: #f6f4e8;
  }

  .road-line {
    fill: none;
    stroke: #efb64c;
    stroke-width: 3;
    stroke-linecap: round;
  }

  .icon-people {
    background: linear-gradient(145deg, #74d9ff, #475ce8);
  }

  .people-path {
    fill: rgba(255, 255, 255, .22);
  }

  .person-main {
    fill: #fff;
    filter: drop-shadow(0 3px 5px rgba(18, 45, 132, .2));
  }

  .person-side {
    fill: rgba(255, 255, 255, .72);
  }

  .icon-code {
    background: linear-gradient(145deg, #30394b, #0e1118);
  }

  .code-window {
    fill: none;
    stroke: rgba(255, 255, 255, .9);
    stroke-width: 2.5;
  }

  .code-dot {
    fill: #ffcf66;
  }

  .code-mark {
    fill: none;
    stroke: #fff;
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  footer {
    position: relative;
    min-height: 28px;
    display: flex;
    justify-content: center;
    align-items: end;
  }

  footer p {
    position: absolute;
    right: 0;
    bottom: 0;
    margin: 0;
    color: rgba(255, 255, 255, .54);
    font-size: 11px;
  }

  .page-dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .page-dots span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255, 255, 255, .34);
  }

  .page-dots span:first-child {
    width: 7px;
    height: 7px;
    background: rgba(255, 255, 255, .9);
  }

  @media (max-width: 720px) {
    .desktop {
      padding-left: max(20px, env(safe-area-inset-left));
      padding-right: max(20px, env(safe-area-inset-right));
    }

    main {
      padding-block: 58px;
    }

    h1 {
      margin-bottom: 38px;
      font-size: 30px;
    }

    .app-grid {
      width: min(470px, 100%);
      grid-template-columns: repeat(2, minmax(100px, 1fr));
      gap: 38px 24px;
    }

    .app-icon {
      width: 88px;
    }
  }

  @media (max-width: 430px) {
    .desktop {
      padding-top: max(18px, env(safe-area-inset-top));
      padding-bottom: max(16px, env(safe-area-inset-bottom));
    }

    .avatar {
      width: 42px;
      height: 42px;
      border-radius: 13px;
    }

    .identity-copy small {
      display: none;
    }

    .status {
      min-height: 36px;
      padding-inline: 11px;
      gap: 8px;
    }

    .wifi {
      display: none;
    }

    main {
      padding-block: 38px;
    }

    h1 {
      margin-bottom: 30px;
      font-size: 27px;
    }

    .app-grid {
      gap: 30px 18px;
    }

    .app-icon {
      width: 80px;
    }

    .app-name {
      font-size: 13px;
    }

    footer {
      align-items: center;
    }

    footer p {
      display: none;
    }
  }

  @media (max-height: 650px) and (min-width: 721px) {
    main {
      padding-block: 38px;
    }

    h1 {
      margin-bottom: 30px;
      font-size: 30px;
    }

    .app-icon {
      width: 82px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-icon {
      transition: none;
    }
  }
</style>
